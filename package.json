{
  "name": "kotoba",
  "version": "0.1.0",
  "private": true,
  "description": "Kotoba desktop app",
  "main": "dist-electron/main/main.cjs",
  "packageManager": "pnpm@9.12.1",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=9 <10"
  },
  "scripts": {
    "check:versions": "node -v && pnpm -v && pnpm list electron typescript react vite --depth 0",
    "dev": "concurrently -k -n RENDERER,MAIN,PRELOAD,ELECTRON -c cyan,green,magenta,yellow \"pnpm dev:renderer\" \"pnpm dev:main\" \"pnpm dev:preload\" \"pnpm dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "esbuild src/main/main.ts --bundle --platform=node --format=cjs --external:electron --external:keytar --outfile=dist-electron/main/main.cjs --watch",
    "dev:preload": "esbuild src/preload/preload.ts --bundle --platform=node --format=cjs --external:electron --outfile=dist-electron/preload/preload.cjs --watch",
    "dev:electron": "wait-on tcp:5173 file:dist-electron/main/main.cjs file:dist-electron/preload/preload.cjs && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "pnpm build:renderer && pnpm build:main && pnpm build:preload",
    "build:renderer": "vite build",
    "build:main": "esbuild src/main/main.ts --bundle --platform=node --format=cjs --external:electron --external:keytar --outfile=dist-electron/main/main.cjs",
    "build:preload": "esbuild src/preload/preload.ts --bundle --platform=node --format=cjs --external:electron --outfile=dist-electron/preload/preload.cjs",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:unit": "vitest run",
    "test:e2e": "pnpm build && playwright test",
    "test": "pnpm test:unit",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm lint && pnpm format:check && pnpm typecheck",
    "prepare": "husky",
    "make:seed-10k": "node scripts/make_seed_10k.mjs",
    "bench:search": "node scripts/bench_search.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "clsx": "^2.1.1",
    "keytar": "^7.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.0.0",
    "cross-env": "^10.0.0",
    "electron": "^40.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.0.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.18",
    "wait-on": "^8.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,cjs,mjs,json,css,html}": [
      "prettier --write"
    ]
  }
}
